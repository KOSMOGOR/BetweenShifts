    - rid: 7092928878738931792
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F \u0441\u043B\u044B\u0448\u0443 \u0438\u0445 \u0433\u043E\u043B\u043E\u0441\u0430...
          \u043E\u043D\u0438 \u0442\u0430\u043C, \u0437\u0430 \u044D\u0442\u0438\u043C...
          \u0437\u043E\u0432\u0443\u0442 \u043C\u0435\u043D\u044F... \u0430 \u044F
