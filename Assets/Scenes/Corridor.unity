    - rid: 7092928878738931802
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042D\u0442\u043E... \u044D\u0442\u043E \u0432\u0442\u043E\u0440\u043E\u0439
          \u043E\u0442\u0440\u044F\u0434. \u041B\u0438\u043D\u0435\u0439\u043A\u0430
          1 \u043C\u0430\u044F. \u042F \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B
          \u041F\u0435\u0442\u044C\u043A\u0443 \u043D\u0430 \u043F\u043B\u0435\u0447\u043E,
          \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0443\u0432\u0438\u0434\u0435\u043B
          \u0441\u0430\u043B\u044E\u0442. \u041E\u043D \u0442\u0430\u043A\u043E\u0439
          \u0441\u043C\u0435\u0448\u043D\u043E\u0439... \u0410 \u0412\u0435\u0440\u0430
          \u0432\u0441\u0435\u0433\u0434\u0430 \u0441\u0442\u0435\u0441\u043D\u044F\u043B\u0430\u0441\u044C,
          \u0430 \u0442\u0443\u0442 \u0443\u043B\u044B\u0431\u0430\u0435\u0442\u0441\u044F..."
        dialogueCharacter: {fileID: 0}
    - rid: 7092928878738931803
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u0422\u043E\u0433\u0434\u0430 \u044F \u0437\u043D\u0430\u043B,
          \u0447\u0442\u043E \u043D\u0430 \u043C\u0435\u043D\u044F \u043C\u043E\u0436\u043D\u043E
          \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C\u0441\u044F. \u0414\u0435\u0442\u0438
          \u0432\u0435\u0440\u0438\u043B\u0438 \u043C\u043D\u0435, \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438
          \u0434\u043E\u0432\u0435\u0440\u044F\u043B\u0438. \u0410 \u0442\u0435\u043F\u0435\u0440\u044C...
          \u044F \u0434\u0430\u0436\u0435 \u0441\u0435\u0431\u044F \u043F\u043E\u0434\u0432\u0435\u0441\u0442\u0438
          \u043D\u0435 \u043C\u043E\u0433\u0443, \u043F\u0440\u043E\u0441\u0442\u043E
          \u0441\u0442\u043E\u044E \u0438 \u0441\u043C\u043E\u0442\u0440\u044E \u043D\u0430
          \u043A\u0430\u043C\u043D\u0438..."
        dialogueCharacter: {fileID: 0}
    - rid: 7092928878738931804
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F \u043D\u0435 \u0438\u043C\u0435\u044E \u043F\u0440\u0430\u0432\u0430
          \u0441\u0434\u0430\u0432\u0430\u0442\u044C\u0441\u044F. \u041E\u043D\u0438
