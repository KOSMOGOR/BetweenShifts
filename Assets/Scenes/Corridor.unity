    - rid: 7092928878738931779
      type: {class: ActionBranchDialogueChoice, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u0422\u044B\u2026 \u0442\u044B \u0432\u0438\u0434\u0438\u0448\u044C
          \u043C\u0435\u043D\u044F?"
        dialogueChoices:
        - choice: "\u0414\u0430, \u0432\u0438\u0436\u0443. \u0427\u0442\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
          label: Next
        - choice: "\u041A\u0442\u043E \u0442\u044B?"
          label: Choice2
        - choice: "(\u041C\u043E\u043B\u0447\u0430 \u0441\u0442\u043E\u044F\u0442\u044C)"
          label: Choice3
        dialogueSpeaker: {fileID: 0}
    - rid: 7092928878738931780
      type: {class: ActionLabel, ns: , asm: Assembly-CSharp}
      data:
        label: MumbleLabel
    - rid: 7092928878738931781
      type: {class: ActionLabel, ns: , asm: Assembly-CSharp}
      data:
        label: Choice2
    - rid: 7092928878738931782
      type: {class: ActionLabel, ns: , asm: Assembly-CSharp}
      data:
        label: Choice3
    - rid: 7092928878738931783
      type: {class: ActionEnd, ns: , asm: Assembly-CSharp}
      data: 
    - rid: 7092928878738931784
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F... \u0421\u0435\u043C\u0451\u043D \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447.
          \u042F \u0444\u0438\u0437\u0440\u0443\u043A \u0437\u0434\u0435\u0441\u044C,
          \u0432 \u0441\u0430\u043D\u0430\u0442\u043E\u0440\u0438\u0438. \u0420\u0430\u0431\u043E\u0442\u0430\u044E
          \u0441 \u0434\u0435\u0442\u044C\u043C\u0438... \u0440\u0430\u0431\u043E\u0442\u0430\u043B...
          \u0410 \u0442\u0435\u043F\u0435\u0440\u044C... \u044F \u043D\u0435 \u0437\u043D\u0430\u044E,
          \u043A\u0442\u043E \u044F. \u042F \u043F\u0440\u043E\u0441\u0442\u043E
          \u0441\u0442\u043E\u044E \u0442\u0443\u0442 \u0438 \u043D\u0438\u0447\u0435\u0433\u043E
          \u043D\u0435 \u043C\u043E\u0433\u0443."
        dialogueCharacter: {fileID: 0}
    - rid: 7092928878738931785
      type: {class: ActionEnd, ns: , asm: Assembly-CSharp}
      data: 
    - rid: 7092928878738931786
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F... \u044F \u043D\u0435 \u0437\u043D\u0430\u044E. \u042F
          \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0438\u0445 \u0432\u044B\u0432\u0435\u0441\u0442\u0438...
          \u0414\u0435\u0442\u0435\u0439. \u041E\u043D\u0438 \u0431\u0435\u0436\u0430\u043B\u0438
          \u0437\u0430 \u043C\u043D\u043E\u0439 \u0438\u0437 \u0441\u043F\u043E\u0440\u0442\u0437\u0430\u043B\u0430,
          \u043A\u043E\u0433\u0434\u0430 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
          \u0442\u0440\u0435\u0432\u043E\u0433\u0430. \u0410 \u043F\u043E\u0442\u043E\u043C\u2026
          \u043F\u043E\u0442\u043E\u043C \u0432\u0441\u0451 \u0440\u0443\u0445\u043D\u0443\u043B\u043E.
          \u042F \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C
          \u0437\u0430\u0432\u0430\u043B, \u043D\u043E \u0440\u0443\u043A\u0438...
          \u043E\u043D\u0438 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u0438
          \u0441\u043A\u0432\u043E\u0437\u044C \u043A\u0430\u043C\u043D\u0438."
        dialogueCharacter: {fileID: 0}
    - rid: 7092928878738931788
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F \u0441\u043B\u0430\u0431\u044B\u0439. \u042F \u0432\u0441\u0435\u0433\u0434\u0430
          \u0431\u044B\u043B \u0441\u0438\u043B\u044C\u043D\u044B\u043C, \u0430 \u0441\u0435\u0439\u0447\u0430\u0441
          \u0434\u0430\u0436\u0435 \u043A\u0430\u043C\u0435\u043D\u044C \u043F\u043E\u0434\u043D\u044F\u0442\u044C
          \u043D\u0435 \u043C\u043E\u0433\u0443..."
        dialogueCharacter: {fileID: 0}
    - rid: 7092928878738931790
      type: {class: ActionChangeState, ns: , asm: Assembly-CSharp}
