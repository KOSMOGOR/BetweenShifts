      data:
        label: Choice3
    - rid: 835268866630484081
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E. \u041C\u044B
          \u0431\u044B\u043B\u0438 \u0432 \u0441\u0442\u043E\u043B\u043E\u0432\u043E\u0439,
          \u043F\u043E\u0442\u043E\u043C \u043C\u0430\u043C\u0430 \u0441\u043A\u0430\u0437\u0430\u043B\u0430,
          \u0447\u0442\u043E \u044D\u0442\u043E \u0443\u0447\u0435\u043D\u0438\u044F,
          \u0438 \u0432\u0435\u043B\u0435\u043B\u0430 \u0438\u0434\u0442\u0438 \u0432
          \u043A\u043E\u043C\u043D\u0430\u0442\u0443. \u0410 \u0441\u0430\u043C\u0430
          \u043F\u043E\u0448\u043B\u0430 \u0437\u0430 \u0431\u0440\u0430\u0442\u0438\u043A\u043E\u043C."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484082
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F \u043F\u0440\u0438\u0448\u043B\u0430 \u0438 \u0441\u0438\u0436\u0443.
          \u0410 \u0442\u0443\u0442 \u043F\u043E\u0442\u043E\u043C \u0441\u0442\u0430\u043B\u043E
          \u0434\u0443\u0448\u043D\u043E, \u0438 \u044F \u043E\u0442\u043A\u0440\u044B\u043B\u0430
          \u0434\u0432\u0435\u0440\u044C, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0434\u044B\u0448\u0430\u0442\u044C..."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484083
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u0410 \u0434\u0430\u043B\u044C\u0448\u0435 \u043D\u0435 \u043F\u043E\u043C\u043D\u044E.
          \u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435, \u044F \u0443\u0441\u043D\u0443\u043B\u0430."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484084
      type: {class: ActionEnd, ns: , asm: Assembly-CSharp}
      data: 
    - rid: 835268866630484085
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u041D\u0435 \u0437\u043D\u0430\u044E, \u043C\u0430\u043C\u0430
          \u0441\u043A\u0430\u0437\u0430\u043B\u0430 \u0436\u0434\u0430\u0442\u044C
          \u0437\u0434\u0435\u0441\u044C. \u041E\u043D\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
          \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043F\u0440\u0430\u0432\u0434\u0443,
          \u0437\u043D\u0430\u0447\u0438\u0442, \u0432\u0435\u0440\u043D\u0451\u0442\u0441\u044F."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484086
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u042F \u043D\u0435 \u043C\u043E\u0433\u0443 \u0443\u0439\u0442\u0438,
          \u043E\u043D\u0430 \u0436\u0435 \u0431\u0443\u0434\u0435\u0442 \u043C\u0435\u043D\u044F
          \u0438\u0441\u043A\u0430\u0442\u044C."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484087
      type: {class: ActionEnd, ns: , asm: Assembly-CSharp}
      data: 
    - rid: 835268866630484088
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u041C\u0430\u043C\u0430 \u043E\u0431\u0435\u0449\u0430\u043B\u0430
          \u0431\u0430\u043D\u0442 \u043F\u0440\u0438\u0448\u0438\u0442\u044C, \u043D\u043E
          \u043D\u0435 \u0443\u0441\u043F\u0435\u043B\u0430. \u041E\u043D\u0430 \u0441\u043A\u0430\u0437\u0430\u043B\u0430:
          \"\u0412\u0435\u0440\u043D\u0443\u0441\u044C \u0438 \u043F\u0440\u0438\u0448\u044C\u044E\".
          \u0410 \u0441\u0430\u043C\u0430 \u043D\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484089
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u041A\u0443\u043A\u043B\u0430 \u0433\u0440\u0443\u0441\u0442\u043D\u0430\u044F
          \u0431\u0435\u0437 \u0431\u0430\u043D\u0442\u0430."
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484092
      type: {class: ActionBranchState, ns: , asm: Assembly-CSharp}
      data:
        trueLabel: Next
        falseLabel: WaitingForDoll
        targetStateName: Init
    - rid: 835268866630484093
