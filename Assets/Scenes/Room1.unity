      data: 
    - rid: 835268866630484095
      type: {class: ActionDialogueText, ns: , asm: Assembly-CSharp}
      data:
        dialogueText: "\u0422\u0430\u043A \u0447\u0442\u043E \u0442\u0430\u043C \u0441
          \u043A\u0443\u043A\u043B\u043E\u0439?"
        dialogueSpeaker: {fileID: 0}
    - rid: 835268866630484096
